# Copy this file to .env and adjust values.
# .env is git-ignored; .env.example is committed as documentation.

# ── Server ───────────────────────────────────────────────────
PORT=8080

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=go_explore
DB_SCHEMA=user_management
DB_SSLMODE=disable
